<% content_for :title, "#{t("search.advanced")} — #{t("search.title")}" %>
<div class="container">
  <h3><%= t("search.advanced") %></h1>
  <%= form_with url: search_path, method: :get, local: true do |form| %>
    <div>
      <div>
        <div role="search">
          <%= form.search_field :q, value: params[:q], placeholder: t("search.placeholder") %>
          <%= form.submit t("helpers.submit.search"), name: "search" %>
        </div>
      </div>
      <div class="grid">
        <div>
          <%= form.label :result %>
          <%= form.select :result, DiseaseCase.enum_options_for_select_with_blank(:result), { selected: params[:result] } %>
        </div>
        <div>
          <%= form.label :year %>
          <%= form.select :year, years_for_select_with_blank, { selected: params[:year] } %>
        </div>
        <div>
          <%= form.label :disease_category %>
          <%= form.select :disease_category, DiseaseCase.enum_options_for_select_with_blank(:disease_category), { selected: params[:disease_category] } %>
        </div>
        <div>
          <%= form.label :body_part %>
          <%= form.select :body_part, DiseaseCase.enum_options_for_select_with_blank(:body_part), { selected: params[:body_part] } %>
        </div>
      </div>
      <div>
        <div class="grid">
          <div>
            <%= form.label :decided_on_from %> <%= form.date_field :decided_on_from, value: params[:decided_on_from] %>
          </div>
          <div>
            <%= form.label :decided_on_to %> <%= form.date_field :decided_on_to, value: params[:decided_on_to] %>
          </div>
        </div>
        <div>
          <%= form.label :sort %>
          <%= form.select :sort, [[t("search.sort_relevance"), "relevance"], [t("search.sort_recent"), "recent"]], { selected: params[:sort] || "relevance" } %>
        </div>
      </div>
    </div>
  <% end %>
  <% if @over_cap %>
    <p class="text-muted"><%= t("search.over_cap") %></p>
  <% elsif @result_count %>
    <p class="text-muted"><%= @result_count %> <%= t("search.results") %></p>
  <% end %>
  <% if @fallback %>
    <div class="alert alert-info"><%= t("search.fallback_notice") %></div>
  <% end %>
  <% if @cases.empty? && (params[:q].present? || params.slice(:result, :year, :disease_category, :body_part, :decided_on_from, :decided_on_to).values.any?(&:present?)) %>
    <p class="text-muted"><%= t("search.no_results") %></p>
  <% elsif @cases.any? %>
    <div class="overflow-x-scroll">
      <%= render "searches/case_list", cases: @cases %>
    </div>
    <div class="max-w-fit mx-auto">
      <%== @pagy.series_nav %>
    </div>
  <% end %>
</div>

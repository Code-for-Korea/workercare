<% content_for :title, @case.disease_name %>

<div style="max-width: 900px; margin: 0 auto;">
  <div class="mb-3">
    <%= link_to "← #{t("search.title")}", root_path, class: "link-secondary" %>
  </div>

  <div class="d-flex justify-content-between align-items-start mb-4">
    <div>
      <h1 class="mb-1"><%= @case.disease_name %></h1>
      <p class="text-muted mb-0">
        연번 <%= @case.case_no %>
        <% if @case.decided_on.present? %>
          &middot; <%= t("disease_case.decided_on") %>: <%= l(@case.decided_on) %>
        <% else %>
          &middot; <%= @case.year %>년
        <% end %>
      </p>
    </div>
    <div class="d-flex gap-2 align-items-center">
      <span class="badge <%= result_badge_class(@case.result) %> fs-6">
        <%= @case.human_attribute_enum(:result) %>
      </span>
      <% if @case.link.present? %>
        <%= link_to "#{t("disease_case.link")} ↗", @case.link,
              target: "_blank", rel: "noopener noreferrer",
              class: "btn btn-outline-secondary btn-sm" %>
      <% end %>
    </div>
  </div>

  <div class="row g-3 mb-4">
    <% if @case.disease_category.present? %>
      <div class="col-auto">
        <span class="badge bg-secondary"><%= @case.human_attribute_enum(:disease_category) %></span>
      </div>
    <% end %>
    <% if @case.body_part.present? %>
      <div class="col-auto">
        <span class="badge bg-light text-dark border"><%= @case.human_attribute_enum(:body_part) %></span>
      </div>
    <% end %>
  </div>

  <% sections = [
    [:statement,           t("disease_case.statement")],
    [:claim_purpose,       t("disease_case.claim_purpose")],
    [:application_content, t("disease_case.application_content")],
    [:applicant_claim,     t("disease_case.applicant_claim")],
    [:medical_records,     t("disease_case.medical_records")],
    [:recognized_facts,    t("disease_case.recognized_facts")],
    [:related_laws,        t("disease_case.related_laws")],
    [:committee_decision,  t("disease_case.committee_decision")]
  ] %>

  <% sections.each do |attr, label| %>
    <% value = @case.public_send(attr) %>
    <% if value.present? %>
      <section class="mb-4">
        <h2 class="h5 border-bottom pb-2"><%= label %></h2>
        <div class="text-body" style="white-space: pre-wrap; line-height: 1.8;"><%= value %></div>
      </section>
    <% end %>
  <% end %>
</div>
